<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Basic Meta Tags -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Sample HTML page with useful meta tags for SEO and social sharing.">
    <meta name="keywords" content="HTML, Meta Tags, SEO, Web Development">
    <meta name="author" content="Your Name">

    <!-- SEO -->
    <meta name="robots" content="index, follow">

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content="My Website">
    <meta property="og:description" content="A sample webpage using HTML meta tags.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://example.com">
    <meta property="og:image" content="https://example.com/image.jpg">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="My Website">
    <meta name="twitter:description" content="A sample webpage using HTML meta tags.">
    <meta name="twitter:image" content="https://example.com/image.jpg">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="favicon.png">

    <title>Meta Tags Example</title>
</head>
<body>

    <header>
        <h1>Welcome to My Website</h1>
    </header>

    <main>
        <p>This HTML page includes commonly used meta tags for SEO and social media sharing.</p>
    </main>

    <footer>
        <p>&copy; 2026 My Website</p>
    </footer>

</body>
</html>
