<!DOCTYPE html>
<html lang="en">
    <head>
        <title>ADDMITION FORM</title>
    </head>
    <body>
        <img src="data:image/png;base64,"
        /><br>
           <h1> ADDMITION FORM </h1>
       Name:
       <input type ="text"  placeholder="Enter your name"><BR><br>
        EMAIL:
        <input type="email" placeholder="Enter your email"><BR><br>
        Mobile Number:
        <input type="tel" pattern="(0-9){10}"placeholder="Enter mobile number"><br><br>
        GENDER:
        <br><BR>
        <input type="radio" name="gender">Male    
        <input type="radio" name="gender">female<br><br>
        DATE OF BIRTH:
        <input type="date" name="dob"><br><br>
        ADDRESS:<br>
        <textarea rows="3"placeholder="Enter your address"></textarea><br>
        <br>
        COURSE:
            <select name="course">
            <option course="BCA">BCA</option>
            <option course="CYBERSECURITY">CYBERSECURITY</option>
            <option course="AIML">AIML"</option>
            <option course="CLOUD COMPUTING">CLOUD COMPUTING</option>
            <option course="DATA SCIENCE">DATA SCIENCE</option>
            <option course="CSE">CSE</option>
            <option course="IT">IT</option>
        </select>
        <br><br>
        PASSWORD:
        <input type ="password"pattern="(?=.*@)(?=.*[0-9])(?=.*[A-Za-z]).{6,}"><BR><br>
        Photo Uploud:
        <input type="file" accept="image/*"><br><br>
        <input type="checkbox" name="terms" required> I Agree to the terms and conditions<br><br>
        <input type="button" name="subit" value="submit">
        
    </body>
    </html>
        
           
        
